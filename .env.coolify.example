# Variáveis a cadastrar no Coolify (Environment Variables do recurso).
# NÃO commitar valores reais. Estes são apenas exemplos/placeholders.

# URL interna do Directus — o container precisa alcançar esse IP/porta na rede.
# Server-side apenas (não vai para o browser).
DIRECTUS_URL=http://192.168.0.118:8056

# Token admin estático do Directus (SEGREDO — marcar como secret no Coolify).
DIRECTUS_TOKEN=coloque_o_token_admin_aqui

# Segredo de sessão — gerar novo valor forte, ex.: `openssl rand -hex 32`.
SESSION_SECRET=gere_um_valor_aleatorio_longo

NODE_ENV=production
PORT=3000
