# URL pública do Directus (usada no client para WebSocket e assets)
NEXT_PUBLIC_DIRECTUS_URL=http://192.168.0.118:8056

# Token admin estático do Directus — USO SERVER-SIDE APENAS. Nunca exponha no client.
DIRECTUS_TOKEN=coloque_seu_token_admin_aqui

# Segredo para assinar/validar cookies de sessão (gere um valor aleatório)
SESSION_SECRET=troque_por_um_valor_aleatorio_longo
